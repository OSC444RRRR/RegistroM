<section id="donaciones-registro-{{ section.id }}" class="dr-app" data-section-id="{{ section.id }}">
  <div class="dr-shell">
    <header class="dr-topbar">
      <div>
        <p class="dr-eyebrow">{{ section.settings.eyebrow }}</p>
        <h2 class="dr-title">{{ section.settings.heading }}</h2>
        <p class="dr-lead">{{ section.settings.subheading }}</p>
      </div>
      <button class="dr-btn dr-btn-ghost" type="button" data-theme-toggle>Modo oscuro</button>
    </header>

    <main class="dr-dashboard">
      <section class="dr-panel dr-hero-panel">
        <div class="dr-stats-grid">
          <article class="dr-stat-card">
            <span class="dr-stat-label">Registros</span>
            <strong data-total-registros>0</strong>
          </article>
          <article class="dr-stat-card">
            <span class="dr-stat-label">Monto total</span>
            <strong data-monto-total>$0</strong>
          </article>
          <article class="dr-stat-card">
            <span class="dr-stat-label">Promedio</span>
            <strong data-promedio-monto>$0</strong>
          </article>
          <article class="dr-stat-card">
            <span class="dr-stat-label">Última hora</span>
            <strong data-ultimo-hora>—</strong>
          </article>
        </div>
      </section>

      <section class="dr-content-grid">
        <section class="dr-panel dr-form-panel">
          <div class="dr-panel-head">
            <div>
              <h3>Nuevo registro</h3>
              <p>Guarda localmente y envía el registro directo al Google Sheet.</p>
            </div>
            <span class="dr-badge">Monto libre desde 100</span>
          </div>

          <form class="dr-form-grid" data-donation-form novalidate>
            <div class="dr-field-row dr-two-cols">
              <label class="dr-field">
                <span>Fecha</span>
                <input type="date" data-fecha required>
              </label>
              <label class="dr-field">
                <span>Hora</span>
                <select data-hora required></select>
              </label>
            </div>

            <label class="dr-field">
              <span>Nombre</span>
              <input type="text" data-nombre maxlength="120" placeholder="Nombre completo" required>
            </label>

            <div class="dr-field-row dr-two-cols">
              <label class="dr-field">
                <span>Teléfono</span>
                <input type="tel" data-telefono maxlength="20" placeholder="6671234567" required>
              </label>
              <label class="dr-field">
                <span>Monto</span>
                <input type="number" data-monto min="100" step="0.01" placeholder="Ej. 250 o 2000" required>
              </label>
            </div>

            <div class="dr-field-row dr-two-cols">
              <label class="dr-field">
                <span>Número de tarjeta</span>
                <input type="text" data-tarjeta maxlength="16" inputmode="numeric" placeholder="16 dígitos" required>
              </label>
              <label class="dr-field">
                <span>Estatus</span>
                <select data-estatus required>
                  <option value="">Selecciona</option>
                  <option>Transferido</option>
                  <option>Tarjeta aprobada</option>
                  <option>Efectivo</option>
                  <option>Pendiente</option>
                  <option>Rechazada</option>
                  <option>Cancelada</option>
                </select>
              </label>
            </div>

            <div class="dr-field-row dr-two-cols">
              <label class="dr-field">
                <span>Método de pago</span>
                <select data-metodo-pago required>
                  <option value="">Selecciona</option>
                  <option>Transferencia</option>
                  <option>Tarjeta</option>
                  <option>Efectivo</option>
                  <option>Depósito</option>
                  <option>Otro</option>
                </select>
              </label>
              <label class="dr-field">
                <span>Capturado por</span>
                <input type="text" data-capturado-por maxlength="80" placeholder="Nombre del operador">
              </label>
            </div>

            <label class="dr-field">
              <span>Notas</span>
              <textarea data-notas rows="4" placeholder="Detalles adicionales"></textarea>
            </label>

            <div class="dr-actions-row">
              <button class="dr-btn dr-btn-primary" type="submit">Guardar registro</button>
              <button class="dr-btn dr-btn-secondary" type="button" data-exportar>Exportar CSV</button>
              <button class="dr-btn dr-btn-danger" type="button" data-limpiar>Borrar respaldo local</button>
            </div>

            <div class="dr-inline-note">
              <p>Si se apaga la PC, el respaldo local puede ayudarte a no perder la captura; además puedes exportar CSV para abrirlo en Excel.</p>
            </div>

            <div class="dr-message" data-mensaje></div>
          </form>
        </section>

        <aside class="dr-side-stack">
          <section class="dr-panel dr-side-panel">
            <div class="dr-panel-head">
              <div>
                <h3>Conteo por monto</h3>
                <p>Resumen automático por cantidad exacta.</p>
              </div>
            </div>
            <div class="dr-amount-list" data-amount-summary></div>
          </section>

          <section class="dr-panel dr-side-panel">
            <div class="dr-panel-head">
              <div>
                <h3>Recomendaciones</h3>
                <p>Úsalas para evitar errores al capturar.</p>
              </div>
            </div>
            <ul class="dr-tips-list">
              <li>La hora solo permite captura entre 7:00 AM y 6:00 PM.</li>
              <li>El monto acepta cualquier valor mayor o igual a 100.</li>
              <li>La tarjeta acepta exactamente 16 dígitos numéricos.</li>
              <li>Haz exportación CSV al final del día como respaldo.</li>
            </ul>
          </section>
        </aside>
      </section>

      <section class="dr-panel dr-table-panel">
        <div class="dr-panel-head dr-table-head">
          <div>
            <h3>Historial local</h3>
            <p>Este historial refleja lo guardado localmente en el navegador.</p>
          </div>
          <input type="search" class="dr-search-input" data-buscar placeholder="Buscar por nombre, teléfono, tarjeta o monto">
        </div>

        <div class="dr-table-wrap">
          <table>
            <thead>
              <tr>
                <th>ID</th>
                <th>Fecha</th>
                <th>Hora</th>
                <th>Nombre</th>
                <th>Teléfono</th>
                <th>Monto</th>
                <th>Tarjeta</th>
                <th>Estatus</th>
                <th>Método</th>
                <th>Capturado por</th>
                <th>Notas</th>
                <th>Acción</th>
              </tr>
            </thead>
            <tbody data-tabla-body>
              <tr>
                <td colspan="12" class="dr-empty-state">Todavía no hay registros.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>
    </main>
  </div>
</section>

