<!-- ============================================================
     JAVASCRIPT
     ============================================================ -->
<script>
(() => {
  const ROOT = document.getElementById('donaciones-registro-{{ section.id }}');
  if (!ROOT || ROOT.dataset.initialized === 'true') return;
  ROOT.dataset.initialized = 'true';

  /* ── CONFIG ── */
  const APPS_URL    = {{ section.settings.apps_script_url | json }};
  const STORAGE_KEY = 'dreg_{{ section.id }}';

  /* ── STATE ── */
  const state = { records: [], filtered: [] };

  /* ── ELEMENTS ── */
  const q  = sel => ROOT.querySelector(sel);
  const el = {
    form:          q('[data-donation-form]'),
    fecha:         q('[data-fecha]'),
    hora:          q('[data-hora]'),
    nombre:        q('[data-nombre]'),
    telefono:      q('[data-telefono]'),
    monto:         q('[data-monto]'),
    tarjeta:       q('[data-tarjeta]'),
    estatus:       q('[data-estatus]'),
    metodoPago:    q('[data-metodo-pago]'),
    notas:         q('[data-notas]'),
    capturadoPor:  q('[data-capturado-por]'),
    kpiRegistros:  q('[data-total-registros]'),
    kpiTotal:      q('[data-monto-total]'),
    kpiPromedio:   q('[data-promedio-monto]'),
    kpiUltimo:     q('[data-ultimo-hora]'),
    amountSummary: q('[data-amount-summary]'),
    tablaBody:     q('[data-tabla-body]'),
    mensaje:       q('[data-mensaje]'),
    btnExportar:   q('[data-exportar]'),
    btnLimpiar:    q('[data-limpiar]'),
    buscar:        q('[data-buscar]'),
    themeToggle:   q('[data-theme-toggle]'),
    submitBtn:     q('[data-submit-btn]')
  };

  /* ══════════════════════════════════════════
     INIT
  ══════════════════════════════════════════ */
  function init() {
    initTheme();
    initHours();
    loadRecords();
    setDefaults();
    bindEvents();
    refresh();
  }

  /* ── THEME ── */
  function initTheme() {
    if (localStorage.getItem('dreg-theme') === 'light') ROOT.classList.add('theme-light');
    syncThemeBtn();
  }
  function syncThemeBtn() {
    const span = el.themeToggle.querySelector('span');
    if (span) span.textContent = ROOT.classList.contains('theme-light') ? 'Modo oscuro' : 'Modo claro';
  }
  function toggleTheme() {
    ROOT.classList.toggle('theme-light');
    localStorage.setItem('dreg-theme', ROOT.classList.contains('theme-light') ? 'light' : 'dark');
    syncThemeBtn();
  }

  /* ── HOURS ── */
  function initHours() {
    el.hora.innerHTML = '<option value="">Selecciona…</option>';
    for (let h = 7; h <= 18; h++) {
      const val = String(h).padStart(2, '0') + ':00';
      const lbl = new Date(2000, 0, 1, h).toLocaleTimeString('es-MX', { hour: 'numeric', minute: '2-digit' });
      const opt = document.createElement('option');
      opt.value = val; opt.textContent = lbl;
      el.hora.appendChild(opt);
    }
  }

  function setDefaults() {
    el.fecha.value = new Date().toISOString().split('T')[0];
  }

  /* ── EVENTS ── */
  function bindEvents() {
    el.form.addEventListener('submit', handleSubmit);
    el.btnExportar.addEventListener('click', exportCSV);
    el.btnLimpiar.addEventListener('click', clearBackup);
    el.buscar.addEventListener('input', refresh);
    el.themeToggle.addEventListener('click', toggleTheme);

    /* Formatear tarjeta con espacios visuales */
    el.tarjeta.addEventListener('input', () => {
      const raw = el.tarjeta.value.replace(/\D/g, '').slice(0, 16);
      el.tarjeta.dataset.rawValue = raw;
      el.tarjeta.value = raw.replace(/(.{4})/g, '$1 ').trim();
    });
  }

  /* ══════════════════════════════════════════
     SUBMIT — CORREGIDO PARA GOOGLE APPS SCRIPT
  ══════════════════════════════════════════ */
  async function handleSubmit(e) {
    e.preventDefault();
    const payload = buildPayload();
    const err = validate(payload);
    if (err) { showMsg(err, 'error'); return; }

    if (!APPS_URL) {
      showMsg('Falta configurar la URL de Apps Script en los ajustes de la sección.', 'error');
      return;
    }

    /* Estado de carga */
    el.submitBtn.disabled = true;
    el.submitBtn.textContent = 'Enviando…';
    showMsg('Enviando a Google Sheets…', 'loading');

    try {
      /*
       * Apps Script requiere:
       *   - método POST
       *   - redirect: 'follow'   (Apps Script redirige con 302)
       *   - Content-Type: 'text/plain'  (no dispara preflight CORS)
       *   - body: JSON string
       */
      const res = await fetch(APPS_URL, {
        method:   'POST',
        redirect: 'follow',
        headers:  { 'Content-Type': 'text/plain;charset=utf-8' },
        body:     JSON.stringify(payload)
      });

      let result;
      try {
        result = await res.json();
      } catch (_) {
        /* Apps Script a veces devuelve texto plano si hay error */
        const text = await res.text().catch(() => '');
        throw new Error('Respuesta inesperada del servidor: ' + text.slice(0, 120));
      }

      if (result && result.ok === false) {
        throw new Error(result.message || 'El servidor rechazó el registro.');
      }

      /* Éxito */
      const saved = { ...payload, id: (result && result.id) ? result.id : ('loc_' + Date.now()) };
      state.records.unshift(saved);
      persist();
      el.form.reset();
      setDefaults();
      refresh();
      showMsg('✓ Registro guardado en Google Sheets.', 'success');

    } catch (err) {
      console.error('[DREG] Error al enviar:', err);
      showMsg('Error: ' + (err.message || 'No se pudo conectar con Google Sheets. Verifica la URL del Apps Script y que esté publicado correctamente.'), 'error');
    } finally {
      el.submitBtn.disabled = false;
      el.submitBtn.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12l5 5L20 7"/></svg> Guardar registro`;
    }
  }

  /* ── PAYLOAD ── */
  function buildPayload() {
    const rawCard = (el.tarjeta.dataset.rawValue || el.tarjeta.value.replace(/\D/g, '')).slice(0, 16);
    return {
      fecha:       el.fecha.value,
      hora:        el.hora.value,
      nombre:      el.nombre.value.trim(),
      telefono:    el.telefono.value.trim(),
      monto:       parseFloat(el.monto.value) || 0,
      tarjeta:     rawCard,
      estatus:     el.estatus.value,
      metodoPago:  el.metodoPago.value,
      notas:       el.notas.value.trim(),
      capturadoPor: el.capturadoPor.value.trim()
    };
  }

  function validate(d) {
    if (!d.fecha)      return 'Selecciona una fecha.';
    if (!d.hora)       return 'Selecciona una hora.';
    if (!d.nombre)     return 'El nombre es obligatorio.';
    if (!d.telefono)   return 'El teléfono es obligatorio.';
    if (!d.estatus)    return 'Selecciona un estatus.';
    if (!d.metodoPago) return 'Selecciona un método de pago.';
    if (!Number.isFinite(d.monto) || d.monto < 100) return 'El monto mínimo es $100.';
    if (!/^\d{16}$/.test(d.tarjeta)) return 'La tarjeta debe tener exactamente 16 dígitos.';
    const h = Number(d.hora.split(':')[0]);
    if (h < 7 || h > 18) return 'La hora debe estar entre 7:00 AM y 6:00 PM.';
    return '';
  }

  /* ── PERSIST ── */
  function persist() {
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state.records)); } catch(_) {}
  }
  function loadRecords() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (raw) { const p = JSON.parse(raw); if (Array.isArray(p)) state.records = p; }
    } catch(_) { state.records = []; }
  }
  function clearBackup() {
    if (!state.records.length) { showMsg('No hay respaldo local.', 'error'); return; }
    if (!confirm('¿Borrar todo el respaldo local?')) return;
    state.records = [];
    localStorage.removeItem(STORAGE_KEY);
    refresh();
    showMsg('Respaldo borrado.', 'success');
  }

  /* ── FILTER ── */
  function refresh() {
    const term = (el.buscar.value || '').trim().toLowerCase();
    state.filtered = term
      ? state.records.filter(r => Object.values(r).join(' ').toLowerCase().includes(term))
      : [...state.records];
    renderKPIs();
    renderAmounts();
    renderTable();
  }

  /* ── RENDER KPIs ── */
  function renderKPIs() {
    const total = state.records.reduce((s, r) => s + Number(r.monto || 0), 0);
    el.kpiRegistros.textContent = state.records.length;
    el.kpiTotal.textContent     = fmt(total);
    el.kpiPromedio.textContent  = fmt(state.records.length ? total / state.records.length : 0);
    el.kpiUltimo.textContent    = state.records.length ? fmtHour(state.records[0].hora) : '—';
  }

  /* ── RENDER AMOUNTS ── */
  function renderAmounts() {
    const map = {};
    state.records.forEach(r => {
      const k = Number(r.monto).toFixed(2);
      map[k] = (map[k] || 0) + 1;
    });
    const keys = Object.keys(map).sort((a, b) => b - a);
    if (!keys.length) {
      el.amountSummary.innerHTML = '<p class="dreg__empty-inline">Sin registros aún.</p>';
      return;
    }
    el.amountSummary.innerHTML = keys.map(k => `
      <div class="dreg__amount-card">
        <strong>${fmt(Number(k))}</strong>
        <span>${map[k]} registro${map[k] === 1 ? '' : 's'}</span>
      </div>`).join('');
  }

  /* ── RENDER TABLE ── */
  function renderTable() {
    if (!state.filtered.length) {
      el.tablaBody.innerHTML = `<tr><td colspan="12" class="dreg__empty">${state.records.length ? 'Sin resultados para esa búsqueda.' : 'Sin registros todavía.'}</td></tr>`;
      return;
    }
    el.tablaBody.innerHTML = state.filtered.map((r, i) => `
      <tr>
        <td>${esc(r.id || '')}</td>
        <td>${esc(r.fecha)}</td>
        <td>${fmtHour(r.hora)}</td>
        <td>${esc(r.nombre)}</td>
        <td>${esc(r.telefono)}</td>
        <td><strong>${fmt(Number(r.monto))}</strong></td>
        <td style="font-family:monospace;letter-spacing:.05em">${esc(r.tarjeta)}</td>
        <td><span class="s-pill ${statusClass(r.estatus)}">${esc(r.estatus)}</span></td>
        <td>${esc(r.metodoPago)}</td>
        <td>${esc(r.capturadoPor || '—')}</td>
        <td style="max-width:160px;white-space:normal">${esc(r.notas || '')}</td>
        <td><button class="dreg__del-btn" data-remove="${esc(r.id || String(i))}">Eliminar</button></td>
      </tr>`).join('');

    el.tablaBody.querySelectorAll('[data-remove]').forEach(btn =>
      btn.addEventListener('click', () => removeRecord(btn.dataset.remove)));
  }

  function removeRecord(id) {
    if (!confirm('¿Eliminar este registro del respaldo local?')) return;
    state.records = state.records.filter(r => String(r.id) !== String(id));
    persist(); refresh();
    showMsg('Registro eliminado.', 'success');
  }

  /* ── EXPORT CSV ── */
  function exportCSV() {
    if (!state.records.length) { showMsg('No hay registros para exportar.', 'error'); return; }
    const cols = ['ID','Fecha','Hora','Nombre','Telefono','Monto','Tarjeta','Estatus','MetodoPago','Notas','CapturadoPor'];
    const rows = [cols, ...state.records.map(r => [
      r.id||'', r.fecha, fmtHour(r.hora), r.nombre, r.telefono,
      r.monto, r.tarjeta, r.estatus, r.metodoPago, r.notas||'', r.capturadoPor||''
    ])];
    const csv  = rows.map(row => row.map(c => `"${String(c).replace(/"/g,'""')}"`).join(',')).join('\n');
    const blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8;' });
    const url  = URL.createObjectURL(blob);
    const a    = Object.assign(document.createElement('a'), { href: url, download: 'donaciones.csv' });
    document.body.appendChild(a); a.click(); a.remove();
    URL.revokeObjectURL(url);
    showMsg('CSV exportado correctamente.', 'success');
  }

  /* ── HELPERS ── */
  function showMsg(text, type) {
    el.mensaje.textContent = text;
    el.mensaje.className   = `dreg__msg show ${type}`;
    clearTimeout(showMsg._t);
    if (type !== 'loading') showMsg._t = setTimeout(() => { el.mensaje.className = 'dreg__msg'; }, 4000);
  }

  function fmt(val) {
    return new Intl.NumberFormat('es-MX', { style: 'currency', currency: 'MXN' }).format(val || 0);
  }

  function fmtHour(v) {
    if (!v) return '—';
    const [h, m] = String(v).split(':').map(Number);
    const d = new Date(); d.setHours(h, m||0, 0, 0);
    return d.toLocaleTimeString('es-MX', { hour: 'numeric', minute: '2-digit' });
  }

  function esc(s) {
    return String(s || '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
  }

  function statusClass(s) {
    return 's-' + String(s || '').toLowerCase().replace(/\s+/g, '-');
  }

  init();
})();
</script>

