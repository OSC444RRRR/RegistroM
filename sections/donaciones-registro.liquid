<section id="donaciones-registro-{{ section.id }}" class="dreg" data-section-id="{{ section.id }}">

  <!-- ░░ FONDO ANIMADO ░░ -->
  <div class="dreg__bg" aria-hidden="true">
    <div class="dreg__orb dreg__orb--1"></div>
    <div class="dreg__orb dreg__orb--2"></div>
    <div class="dreg__orb dreg__orb--3"></div>
    <div class="dreg__grid"></div>
  </div>

  <div class="dreg__wrap">

    <!-- ░░ HERO ░░ -->
    <header class="dreg__hero">
      <div class="dreg__hero-left">
        <span class="dreg__badge">
          <span class="dreg__badge-dot"></span>
          {{ section.settings.eyebrow }}
        </span>
        <h1 class="dreg__title">{{ section.settings.heading }}</h1>
        <p class="dreg__sub">{{ section.settings.subheading }}</p>
      </div>

      <div class="dreg__kpis">
        <div class="dreg__kpi">
          <span class="dreg__kpi-icon">📋</span>
          <strong data-total-registros>0</strong>
          <span>Registros</span>
        </div>
        <div class="dreg__kpi dreg__kpi--accent">
          <span class="dreg__kpi-icon">💰</span>
          <strong data-monto-total>$0</strong>
          <span>Total</span>
        </div>
        <div class="dreg__kpi">
          <span class="dreg__kpi-icon">📊</span>
          <strong data-promedio-monto>$0</strong>
          <span>Promedio</span>
        </div>
        <div class="dreg__kpi">
          <span class="dreg__kpi-icon">🕐</span>
          <strong data-ultimo-hora>—</strong>
          <span>Último</span>
        </div>
      </div>
    </header>

    <!-- ░░ CONTENIDO PRINCIPAL ░░ -->
    <div class="dreg__body">

      <!-- FORMULARIO -->
      <div class="dreg__card dreg__form-card">
        <div class="dreg__card-header">
          <div class="dreg__card-title-block">
            <span class="dreg__card-label">Captura manual</span>
            <h2 class="dreg__card-title">Nuevo registro</h2>
          </div>
          <button type="button" class="dreg__theme-btn" data-theme-toggle>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
            <span>Modo claro</span>
          </button>
        </div>

        <form class="dreg__form" data-donation-form novalidate>
          <div class="dreg__row">
            <label class="dreg__field">
              <span class="dreg__field-label">Fecha</span>
              <input type="date" data-fecha required class="dreg__input">
            </label>
            <label class="dreg__field">
              <span class="dreg__field-label">Hora</span>
              <select data-hora required class="dreg__input"></select>
            </label>
          </div>

          <label class="dreg__field">
            <span class="dreg__field-label">Nombre completo</span>
            <input type="text" data-nombre maxlength="120" placeholder="Nombre del donante" required class="dreg__input">
          </label>

          <div class="dreg__row">
            <label class="dreg__field">
              <span class="dreg__field-label">Teléfono</span>
              <input type="tel" data-telefono maxlength="20" placeholder="6671234567" required class="dreg__input">
            </label>
            <label class="dreg__field">
              <span class="dreg__field-label">Monto (MXN)</span>
              <div class="dreg__input-prefix">
                <span>$</span>
                <input type="number" data-monto min="100" step="0.01" placeholder="250" required class="dreg__input dreg__input--prefixed">
              </div>
            </label>
          </div>

          <div class="dreg__row">
            <label class="dreg__field">
              <span class="dreg__field-label">Número de tarjeta</span>
              <input type="text" data-tarjeta maxlength="19" inputmode="numeric" placeholder="•••• •••• •••• ••••" required class="dreg__input dreg__input--mono">
            </label>
            <label class="dreg__field">
              <span class="dreg__field-label">Estatus</span>
              <select data-estatus required class="dreg__input">
                <option value="">Selecciona…</option>
                <option>Transferido</option>
                <option>Tarjeta aprobada</option>
                <option>Efectivo</option>
                <option>Pendiente</option>
                <option>Rechazada</option>
                <option>Cancelada</option>
              </select>
            </label>
          </div>

          <div class="dreg__row">
            <label class="dreg__field">
              <span class="dreg__field-label">Método de pago</span>
              <select data-metodo-pago required class="dreg__input">
                <option value="">Selecciona…</option>
                <option>Transferencia</option>
                <option>Tarjeta</option>
                <option>Efectivo</option>
                <option>Depósito</option>
                <option>Otro</option>
              </select>
            </label>
            <label class="dreg__field">
              <span class="dreg__field-label">Capturado por</span>
              <input type="text" data-capturado-por maxlength="80" placeholder="Nombre del operador" class="dreg__input">
            </label>
          </div>

          <label class="dreg__field">
            <span class="dreg__field-label">Notas</span>
            <textarea data-notas rows="3" placeholder="Detalles adicionales…" class="dreg__input dreg__input--textarea"></textarea>
          </label>

          <div class="dreg__actions">
            <button class="dreg__btn dreg__btn--primary" type="submit" data-submit-btn>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12l5 5L20 7"/></svg>
              Guardar registro
            </button>
            <button class="dreg__btn dreg__btn--ghost" type="button" data-exportar>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Exportar CSV
            </button>
            <button class="dreg__btn dreg__btn--danger" type="button" data-limpiar>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6M14 11v6"/></svg>
              Limpiar
            </button>
          </div>

          <div class="dreg__hint">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            Captura entre 7:00 AM y 6:00 PM · Monto mínimo $100 · Tarjeta 16 dígitos
          </div>

          <div class="dreg__msg" data-mensaje></div>
        </form>
      </div>

      <!-- SIDEBAR -->
      <aside class="dreg__sidebar">
        <div class="dreg__card">
          <div class="dreg__card-header dreg__card-header--simple">
            <span class="dreg__card-label">Análisis</span>
            <h2 class="dreg__card-title">Montos</h2>
          </div>
          <div class="dreg__amounts" data-amount-summary>
            <p class="dreg__empty-inline">Sin registros aún.</p>
          </div>
        </div>

        <div class="dreg__card">
          <div class="dreg__card-header dreg__card-header--simple">
            <span class="dreg__card-label">Tips</span>
            <h2 class="dreg__card-title">Buenas prácticas</h2>
          </div>
          <ul class="dreg__tips">
            <li>Exporta CSV al terminar el turno.</li>
            <li>Verifica teléfono y monto antes de guardar.</li>
            <li>Si cambia el Apps Script, actualiza la URL.</li>
            <li>El historial local es un respaldo de navegador.</li>
          </ul>
        </div>
      </aside>
    </div>

    <!-- ░░ TABLA ░░ -->
    <div class="dreg__card dreg__table-card">
      <div class="dreg__card-header dreg__card-header--table">
        <div>
          <span class="dreg__card-label">Respaldo local</span>
          <h2 class="dreg__card-title">Historial de registros</h2>
        </div>
        <div class="dreg__search-wrap">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input type="search" class="dreg__search" data-buscar placeholder="Buscar…">
        </div>
      </div>

      <div class="dreg__table-scroll">
        <table class="dreg__table">
          <thead>
            <tr>
              <th>ID</th><th>Fecha</th><th>Hora</th><th>Nombre</th>
              <th>Teléfono</th><th>Monto</th><th>Tarjeta</th>
              <th>Estatus</th><th>Método</th><th>Capturado por</th>
              <th>Notas</th><th></th>
            </tr>
          </thead>
          <tbody data-tabla-body>
            <tr><td colspan="12" class="dreg__empty">Sin registros todavía.</td></tr>
          </tbody>
        </table>
      </div>
    </div>

  </div><!-- /wrap -->
</section>

<!-- ============================================================
     ESTILOS
     ============================================================ -->
<style>
/* ── TOKENS ──────────────────────────────────────────────────── */
#shopify-section-{{ section.id }} .dreg {
  --c-bg:       #05080f;
  --c-surface:  #0c1120;
  --c-card:     rgba(255,255,255,.045);
  --c-border:   rgba(255,255,255,.08);
  --c-text:     #e8edf8;
  --c-muted:    #6b7ca8;
  --c-primary:  {{ section.settings.primary_color }};
  --c-accent:   {{ section.settings.secondary_color }};
  --c-success:  #22c55e;
  --c-warn:     #f59e0b;
  --c-danger:   #f43f5e;
  --r-card:     20px;
  --r-input:    12px;
  --r-btn:      12px;
  --shadow-card: 0 1px 0 rgba(255,255,255,.06) inset, 0 24px 64px rgba(0,0,0,.4);
  font-family: 'DM Sans', 'Outfit', system-ui, sans-serif;
  background: var(--c-bg);
  color: var(--c-text);
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  position: relative;
  overflow: hidden;
}

/* Light mode */
#shopify-section-{{ section.id }} .dreg.theme-light {
  --c-bg:      #f0f4ff;
  --c-surface: #e4eaf8;
  --c-card:    rgba(255,255,255,.7);
  --c-border:  rgba(0,0,0,.09);
  --c-text:    #0b1226;
  --c-muted:   #556080;
  --shadow-card: 0 1px 0 rgba(255,255,255,.9) inset, 0 8px 32px rgba(0,0,50,.1);
}

#shopify-section-{{ section.id }} .dreg * { box-sizing: border-box; }

/* ── FONDO ───────────────────────────────────────────────────── */
#shopify-section-{{ section.id }} .dreg__bg {
  position: absolute; inset: 0; pointer-events: none; z-index: 0;
}
#shopify-section-{{ section.id }} .dreg__orb {
  position: absolute; border-radius: 50%; filter: blur(90px); opacity: .55;
  animation: orbFloat 12s ease-in-out infinite alternate;
}
#shopify-section-{{ section.id }} .dreg__orb--1 {
  width: 500px; height: 500px; top: -120px; left: -80px;
  background: radial-gradient(circle, var(--c-primary) 0%, transparent 70%);
  opacity: .18;
}
#shopify-section-{{ section.id }} .dreg__orb--2 {
  width: 400px; height: 400px; top: 40%; right: -100px;
  background: radial-gradient(circle, var(--c-accent) 0%, transparent 70%);
  opacity: .14; animation-delay: -5s;
}
#shopify-section-{{ section.id }} .dreg__orb--3 {
  width: 350px; height: 350px; bottom: -60px; left: 30%;
  background: radial-gradient(circle, #ec4899 0%, transparent 70%);
  opacity: .10; animation-delay: -8s;
}
#shopify-section-{{ section.id }} .dreg__grid {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,.025) 1px, transparent 1px);
  background-size: 48px 48px;
}
.dreg.theme-light .dreg__grid {
  background-image:
    linear-gradient(rgba(0,0,80,.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,0,80,.04) 1px, transparent 1px);
}
@keyframes orbFloat {
  from { transform: translate(0, 0) scale(1); }
  to   { transform: translate(30px, 20px) scale(1.05); }
}

/* ── LAYOUT ──────────────────────────────────────────────────── */
#shopify-section-{{ section.id }} .dreg__wrap {
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 20px;
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  gap: 20px;
}

/* ── HERO ────────────────────────────────────────────────────── */
#shopify-section-{{ section.id }} .dreg__hero {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 24px;
  align-items: center;
  padding: 32px 36px;
  background: var(--c-card);
  border: 1px solid var(--c-border);
  border-radius: var(--r-card);
  box-shadow: var(--shadow-card);
  backdrop-filter: blur(16px);
}
#shopify-section-{{ section.id }} .dreg__badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 6px 14px 6px 10px;
  border-radius: 999px;
  background: rgba(255,255,255,.06);
  border: 1px solid var(--c-border);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--c-accent);
  margin-bottom: 16px;
}
#shopify-section-{{ section.id }} .dreg__badge-dot {
  width: 6px; height: 6px;
  background: var(--c-success);
  border-radius: 50%;
  animation: pulse 2s ease-in-out infinite;
}
@keyframes pulse {
  0%,100% { opacity: 1; transform: scale(1); }
  50% { opacity: .5; transform: scale(.8); }
}
#shopify-section-{{ section.id }} .dreg__title {
  margin: 0 0 10px;
  font-size: clamp(2rem, 4vw, 3.6rem);
  font-weight: 800;
  letter-spacing: -0.04em;
  line-height: 1;
  background: linear-gradient(135deg, var(--c-text) 40%, var(--c-accent));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
#shopify-section-{{ section.id }} .dreg__sub {
  margin: 0;
  color: var(--c-muted);
  line-height: 1.65;
  max-width: 480px;
  font-size: .95rem;
}
#shopify-section-{{ section.id }} .dreg__kpis {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
}
#shopify-section-{{ section.id }} .dreg__kpi {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  padding: 16px 14px;
  border-radius: 16px;
  background: rgba(255,255,255,.04);
  border: 1px solid var(--c-border);
  text-align: center;
  min-width: 90px;
}
#shopify-section-{{ section.id }} .dreg__kpi--accent {
  background: linear-gradient(135deg, rgba(124,92,255,.12), rgba(34,211,238,.08));
  border-color: rgba(124,92,255,.25);
}
#shopify-section-{{ section.id }} .dreg__kpi-icon { font-size: 1.2rem; }
#shopify-section-{{ section.id }} .dreg__kpi strong {
  font-size: 1.1rem;
  font-weight: 800;
  letter-spacing: -0.02em;
  color: var(--c-text);
}
#shopify-section-{{ section.id }} .dreg__kpi span {
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: .08em;
  color: var(--c-muted);
  font-weight: 600;
}

/* ── BODY GRID ───────────────────────────────────────────────── */
#shopify-section-{{ section.id }} .dreg__body {
  display: grid;
  grid-template-columns: minmax(0, 1.6fr) 320px;
  gap: 20px;
  align-items: start;
}

/* ── CARDS ───────────────────────────────────────────────────── */
#shopify-section-{{ section.id }} .dreg__card {
  background: var(--c-card);
  border: 1px solid var(--c-border);
  border-radius: var(--r-card);
  box-shadow: var(--shadow-card);
  backdrop-filter: blur(16px);
  padding: 28px;
}
#shopify-section-{{ section.id }} .dreg__card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24px;
  gap: 12px;
}
#shopify-section-{{ section.id }} .dreg__card-header--simple { margin-bottom: 18px; }
#shopify-section-{{ section.id }} .dreg__card-header--table {
  align-items: center;
  flex-wrap: wrap;
}
#shopify-section-{{ section.id }} .dreg__card-label {
  display: block;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--c-accent);
  margin-bottom: 4px;
}
#shopify-section-{{ section.id }} .dreg__card-title {
  margin: 0;
  font-size: 1.1rem;
  font-weight: 700;
  letter-spacing: -0.02em;
}

/* ── SIDEBAR ─────────────────────────────────────────────────── */
#shopify-section-{{ section.id }} .dreg__sidebar {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

/* ── FORM ────────────────────────────────────────────────────── */
#shopify-section-{{ section.id }} .dreg__form {
  display: flex;
  flex-direction: column;
  gap: 14px;
}
#shopify-section-{{ section.id }} .dreg__row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
}
#shopify-section-{{ section.id }} .dreg__field {
  display: flex;
  flex-direction: column;
  gap: 7px;
}
#shopify-section-{{ section.id }} .dreg__field-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--c-muted);
}
#shopify-section-{{ section.id }} .dreg__input {
  width: 100%;
  padding: 11px 14px;
  background: rgba(255,255,255,.05);
  border: 1px solid var(--c-border);
  border-radius: var(--r-input);
  color: var(--c-text);
  font-size: .9rem;
  outline: none;
  transition: border-color .15s, box-shadow .15s, background .15s;
  appearance: none;
  -webkit-appearance: none;
}
#shopify-section-{{ section.id }} .dreg__input::placeholder { color: var(--c-muted); opacity: .7; }
#shopify-section-{{ section.id }} .dreg__input:focus {
  border-color: var(--c-primary);
  box-shadow: 0 0 0 3px rgba(124,92,255,.18);
  background: rgba(255,255,255,.07);
}
#shopify-section-{{ section.id }} .dreg__input--mono { font-family: 'Courier New', monospace; letter-spacing: .08em; }
#shopify-section-{{ section.id }} .dreg__input--textarea { min-height: 90px; resize: vertical; }
#shopify-section-{{ section.id }} .dreg__input-prefix {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,.05);
  border: 1px solid var(--c-border);
  border-radius: var(--r-input);
  overflow: hidden;
  transition: border-color .15s, box-shadow .15s;
}
#shopify-section-{{ section.id }} .dreg__input-prefix:focus-within {
  border-color: var(--c-primary);
  box-shadow: 0 0 0 3px rgba(124,92,255,.18);
}
#shopify-section-{{ section.id }} .dreg__input-prefix > span {
  padding: 0 12px;
  font-weight: 700;
  color: var(--c-muted);
  font-size: .85rem;
  border-right: 1px solid var(--c-border);
  line-height: 1;
  white-space: nowrap;
}
#shopify-section-{{ section.id }} .dreg__input--prefixed {
  border: none !important;
  box-shadow: none !important;
  border-radius: 0 var(--r-input) var(--r-input) 0;
  background: transparent;
}

/* Light mode inputs */
#shopify-section-{{ section.id }} .dreg.theme-light .dreg__input,
#shopify-section-{{ section.id }} .dreg.theme-light .dreg__input-prefix {
  background: rgba(255,255,255,.75);
  border-color: rgba(0,0,80,.12);
}
#shopify-section-{{ section.id }} .dreg.theme-light .dreg__input:focus {
  background: #fff;
}

/* ── BOTONES ─────────────────────────────────────────────────── */
#shopify-section-{{ section.id }} .dreg__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}
#shopify-section-{{ section.id }} .dreg__btn {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 11px 18px;
  border: none;
  border-radius: var(--r-btn);
  font-size: .875rem;
  font-weight: 700;
  cursor: pointer;
  transition: transform .15s, opacity .15s, box-shadow .15s;
  white-space: nowrap;
}
#shopify-section-{{ section.id }} .dreg__btn:hover { transform: translateY(-2px); }
#shopify-section-{{ section.id }} .dreg__btn:active { transform: translateY(0); }
#shopify-section-{{ section.id }} .dreg__btn--primary {
  background: linear-gradient(135deg, var(--c-primary), var(--c-accent));
  color: #fff;
  box-shadow: 0 4px 20px rgba(124,92,255,.35);
}
#shopify-section-{{ section.id }} .dreg__btn--primary:hover {
  box-shadow: 0 6px 28px rgba(124,92,255,.5);
}
#shopify-section-{{ section.id }} .dreg__btn--ghost {
  background: rgba(255,255,255,.07);
  border: 1px solid var(--c-border);
  color: var(--c-text);
}
#shopify-section-{{ section.id }} .dreg__btn--danger {
  background: rgba(244,63,94,.12);
  border: 1px solid rgba(244,63,94,.25);
  color: #fb7185;
}
#shopify-section-{{ section.id }} .dreg__btn:disabled {
  opacity: .5; cursor: not-allowed; transform: none;
}
#shopify-section-{{ section.id }} .dreg__theme-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 9px 14px;
  background: rgba(255,255,255,.06);
  border: 1px solid var(--c-border);
  border-radius: var(--r-btn);
  color: var(--c-muted);
  font-size: .8rem;
  font-weight: 600;
  cursor: pointer;
  transition: color .15s, background .15s;
  white-space: nowrap;
}
