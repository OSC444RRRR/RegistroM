<section>
  <h1>{{ section.settings.heading }}</h1>
  <p>{{ section.settings.subheading }}</p>
</section>

{% schema %}
{
  "name": "Registro donaciones",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Registro de Donaciones"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subtítulo",
      "default": "Sección de prueba"
    }
  ],
  "presets": [
    {
      "name": "Registro donaciones"
    }
  ]
}
{% endschema %}