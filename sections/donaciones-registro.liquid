<script>
(() => {
  const section = document.getElementById('donaciones-registro-{{ section.id }}');
  if (!section || section.dataset.initialized === 'true') return;
  section.dataset.initialized = 'true';

  const APPS_SCRIPT_URL = {{ section.settings.apps_script_url | json }};
  const STORAGE_KEY = 'registroDonacionesShopify_{{ section.id }}';

  const state = {
    records: [],
    filteredRecords: []
  };

  const els = {
    form: section.querySelector('[data-donation-form]'),
    fecha: section.querySelector('[data-fecha]'),
    hora: section.querySelector('[data-hora]'),
    nombre: section.querySelector('[data-nombre]'),
    telefono: section.querySelector('[data-telefono]'),
    monto: section.querySelector('[data-monto]'),
    tarjeta: section.querySelector('[data-tarjeta]'),
    estatus: section.querySelector('[data-estatus]'),
    metodoPago: section.querySelector('[data-metodo-pago]'),
    notas: section.querySelector('[data-notas]'),
    capturadoPor: section.querySelector('[data-capturado-por]'),
    totalRegistros: section.querySelector('[data-total-registros]'),
    montoTotal: section.querySelector('[data-monto-total]'),
    promedioMonto: section.querySelector('[data-promedio-monto]'),
    ultimoHora: section.querySelector('[data-ultimo-hora]'),
    amountSummary: section.querySelector('[data-amount-summary]'),
    tablaBody: section.querySelector('[data-tabla-body]'),
    mensaje: section.querySelector('[data-mensaje]'),
    btnExportar: section.querySelector('[data-exportar]'),
    btnLimpiar: section.querySelector('[data-limpiar]'),
    buscar: section.querySelector('[data-buscar]'),
    themeToggle: section.querySelector('[data-theme-toggle]')
  };

  function init() {
    initTheme();
    initHours();
    loadRecords();
    setDefaultFormValues();
    attachEvents();
    applyFilter();
  }

  function initTheme() {
    const saved = localStorage.getItem('donation-ui-theme');
    if (saved === 'light') section.classList.add('theme-light');
    updateThemeButton();
  }

  function updateThemeButton() {
    els.themeToggle.textContent = section.classList.contains('theme-light') ? 'Modo oscuro' : 'Modo claro';
  }

  function toggleTheme() {
    section.classList.toggle('theme-light');
    localStorage.setItem('donation-ui-theme', section.classList.contains('theme-light') ? 'light' : 'dark');
    updateThemeButton();
  }

  function initHours() {
    els.hora.innerHTML = '<option value="">Selecciona</option>';
    for (let h = 7; h <= 18; h++) {
      const value = String(h).padStart(2, '0') + ':00';
      const label = new Date(2025, 0, 1, h, 0).toLocaleTimeString('es-MX', {
        hour: 'numeric',
        minute: '2-digit'
      });
      const option = document.createElement('option');
      option.value = value;
      option.textContent = label;
      els.hora.appendChild(option);
    }
  }

  function attachEvents() {
    els.form.addEventListener('submit', handleSubmit);
    els.btnExportar.addEventListener('click', exportCsv);
    els.btnLimpiar.addEventListener('click', clearLocalBackup);
    els.buscar.addEventListener('input', applyFilter);
    els.themeToggle.addEventListener('click', toggleTheme);
    els.tarjeta.addEventListener('input', () => {
      els.tarjeta.value = els.tarjeta.value.replace(/\D/g, '').slice(0, 16);
    });
  }

  function setDefaultFormValues() {
    els.fecha.value = new Date().toISOString().split('T')[0];
    els.monto.value = '100';
  }

  function validateCardNumber(value) {
    const digits = String(value || '').replace(/\D/g, '');
    return /^\d{16}$/.test(digits) ? digits : '';
  }

  function buildPayload() {
    return {
      fecha: els.fecha.value,
      hora: els.hora.value,
      nombre: els.nombre.value.trim(),
      telefono: els.telefono.value.trim(),
      monto: Number(els.monto.value),
      tarjeta: validateCardNumber(els.tarjeta.value),
      estatus: els.estatus.value,
      metodoPago: els.metodoPago.value,
      notas: els.notas.value.trim(),
      capturadoPor: els.capturadoPor.value.trim()
    };
  }

  function validatePayload(data) {
    if (!APPS_SCRIPT_URL) return 'Falta configurar la URL de Apps Script.';
    if (!data.fecha || !data.hora || !data.nombre || !data.telefono || !data.estatus || !data.metodoPago) {
      return 'Completa todos los campos obligatorios.';
    }
    if (!Number.isFinite(data.monto) || data.monto < 100) return 'El monto debe ser mayor o igual a 100.';
    if (!data.tarjeta) return 'La tarjeta debe tener exactamente 16 dígitos.';
    const hour = Number(data.hora.split(':')[0]);
    if (hour < 7 || hour > 18) return 'La hora debe estar entre 7:00 AM y 6:00 PM.';
    return '';
  }

  async function handleSubmit(e) {
    e.preventDefault();
    const payload = buildPayload();
    const error = validatePayload(payload);

    if (error) {
      showMessage(error, 'error');
      return;
    }

    try {
      const response = await fetch(APPS_SCRIPT_URL, {
        method: 'POST',
        redirect: 'follow',
        headers: { 'Content-Type': 'text/plain;charset=utf-8' },
        body: JSON.stringify(payload)
      });

      const result = await response.json();

      if (!result.ok) {
        showMessage(result.message || 'No se pudo guardar en Google Sheets.', 'error');
        return;
      }

      const record = { ...payload, id: result.id };
      state.records.unshift(record);
      persistRecords();
      els.form.reset();
      setDefaultFormValues();
      applyFilter();
      showMessage('Registro guardado correctamente.', 'success');
    } catch (err) {
      showMessage('No se pudo conectar con Google Sheets. Revisa el Apps Script.', 'error');
    }
  }

  function persistRecords() {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(state.records));
  }

  function loadRecords() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return;
      const parsed = JSON.parse(raw);
      if (Array.isArray(parsed)) state.records = parsed;
    } catch (e) {
      state.records = [];
    }
  }

  function clearLocalBackup() {
    if (!state.records.length) {
      showMessage('No hay respaldo local para borrar.', 'error');
      return;
    }

    const ok = confirm('¿Seguro que quieres borrar el respaldo local?');
    if (!ok) return;

    state.records = [];
    localStorage.removeItem(STORAGE_KEY);
    applyFilter();
    showMessage('Respaldo local borrado correctamente.', 'success');
  }

  function applyFilter() {
    const term = els.buscar.value.trim().toLowerCase();
    state.filteredRecords = state.records.filter(record => {
      if (!term) return true;
      return [
        record.id,
        record.fecha,
        record.hora,
        record.nombre,
        record.telefono,
        record.monto,
        record.tarjeta,
        record.estatus,
        record.metodoPago,
        record.capturadoPor,
        record.notas
      ].join(' ').toLowerCase().includes(term);
    });

    renderStats();
    renderAmountSummary();
    renderTable();
  }

  function renderStats() {
    const total = state.records.reduce((sum, record) => sum + Number(record.monto || 0), 0);
    els.totalRegistros.textContent = state.records.length;
    els.montoTotal.textContent = formatCurrency(total);
    els.promedioMonto.textContent = formatCurrency(state.records.length ? total / state.records.length : 0);
    els.ultimoHora.textContent = state.records.length ? formatHour(state.records[0].hora) : '—';
  }

  function renderAmountSummary() {
    const counts = {};
    state.records.forEach(record => {
      const key = Number(record.monto).toFixed(2);
      counts[key] = (counts[key] || 0) + 1;
    });

    const keys = Object.keys(counts).sort((a, b) => Number(a) - Number(b));

    if (!keys.length) {
      els.amountSummary.innerHTML = '<div class="amount-card"><strong>Sin datos</strong><span>Los montos aparecerán aquí.</span></div>';
      return;
    }

    els.amountSummary.innerHTML = keys.map(key => `
      <div class="amount-card">
        <strong>${formatCurrency(Number(key))}</strong>
        <span>${counts[key]} registro${counts[key] === 1 ? '' : 's'}</span>
      </div>
    `).join('');
  }

  function renderTable() {
    if (!state.filteredRecords.length) {
      els.tablaBody.innerHTML = '<tr><td colspan="12" class="empty-state">No hay registros que coincidan con tu búsqueda.</td></tr>';
      return;
    }

    els.tablaBody.innerHTML = state.filteredRecords.map((record, index) => `
      <tr>
        <td>${escapeHtml(record.id || '')}</td>
        <td>${escapeHtml(record.fecha)}</td>
        <td>${formatHour(record.hora)}</td>
        <td>${escapeHtml(record.nombre)}</td>
        <td>${escapeHtml(record.telefono)}</td>
        <td>${formatCurrency(Number(record.monto))}</td>
        <td>${escapeHtml(record.tarjeta)}</td>
        <td><span class="status-pill ${statusClass(record.estatus)}">${escapeHtml(record.estatus)}</span></td>
        <td>${escapeHtml(record.metodoPago)}</td>
        <td>${escapeHtml(record.capturadoPor || '')}</td>
        <td>${escapeHtml(record.notas || '')}</td>
        <td><button class="table-btn" type="button" data-remove="${escapeHtml(record.id || String(index))}">Eliminar</button></td>
      </tr>
    `).join('');

    els.tablaBody.querySelectorAll('[data-remove]').forEach(btn => {
      btn.addEventListener('click', () => removeRecord(btn.getAttribute('data-remove')));
    });
  }

  function removeRecord(id) {
    const ok = confirm('¿Seguro que quieres eliminar este registro del respaldo local?');
    if (!ok) return;
    state.records = state.records.filter(record => String(record.id) !== String(id));
    persistRecords();
    applyFilter();
    showMessage('Registro eliminado.', 'success');
  }

  function exportCsv() {
    if (!state.records.length) {
      showMessage('No hay registros para exportar.', 'error');
      return;
    }

    const rows = [
      ['ID', 'Fecha', 'Hora', 'Nombre', 'Telefono', 'Monto', 'NumeroTarjeta', 'Estatus', 'MetodoPago', 'Notas', 'CapturadoPor'],
      ...state.records.map(record => [
        record.id || '',
        record.fecha,
        formatHour(record.hora),
        record.nombre,
        record.telefono,
        record.monto,
        record.tarjeta,
        record.estatus,
        record.metodoPago,
        record.notas || '',
        record.capturadoPor || ''
      ])
    ];

    const csv = rows.map(row => row.map(cell => `"${String(cell).replace(/"/g, '""')}"`).join(',')).join('\n');
    const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'registro-donaciones.csv';
    document.body.appendChild(a);
    a.click();
    a.remove();
    URL.revokeObjectURL(url);
    showMessage('CSV exportado correctamente.', 'success');
  }

  function showMessage(text, type) {
    els.mensaje.textContent = text;
    els.mensaje.className = `form-message show ${type}`;
    clearTimeout(showMessage.timer);
    showMessage.timer = setTimeout(() => {
      els.mensaje.className = 'form-message';
    }, 3500);
  }

  function formatCurrency(value) {
    return new Intl.NumberFormat('es-MX', {
      style: 'currency',
      currency: 'MXN'
    }).format(value || 0);
  }

  function formatHour(value) {
    if (!value) return '—';
    const [h, m] = String(value).split(':').map(Number);
    const d = new Date();
    d.setHours(h, m, 0, 0);
    return d.toLocaleTimeString('es-MX', { hour: 'numeric', minute: '2-digit' });
  }

  function escapeHtml(str) {
    return String(str).replace(/[&<>"']/g, c => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;'
    }[c]));
  }

  function statusClass(status) {
    return 's-' + String(status || '').toLowerCase().replace(/\s+/g, '-');
  }

  init();
})();
</script>

