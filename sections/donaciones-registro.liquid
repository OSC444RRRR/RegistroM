<section id="donaciones-registro-{{ section.id }}" class="donation-ui" data-section-id="{{ section.id }}">
  <div class="donation-ui__bg"></div>

  <div class="donation-ui__container">
    <header class="donation-ui__hero">
      <div class="donation-ui__hero-copy">
        <span class="donation-ui__eyebrow">{{ section.settings.eyebrow }}</span>
        <h1 class="donation-ui__title">{{ section.settings.heading }}</h1>
        <p class="donation-ui__subtitle">{{ section.settings.subheading }}</p>
      </div>

      <div class="donation-ui__hero-card">
        <div class="donation-ui__hero-badge">Panel conectado a Google Sheets</div>
        <div class="donation-ui__hero-stats">
          <div class="metric-card">
            <span>Registros</span>
            <strong data-total-registros>0</strong>
          </div>
          <div class="metric-card">
            <span>Total</span>
            <strong data-monto-total>$0</strong>
          </div>
          <div class="metric-card">
            <span>Promedio</span>
            <strong data-promedio-monto>$0</strong>
          </div>
          <div class="metric-card">
            <span>Última hora</span>
            <strong data-ultimo-hora>—</strong>
          </div>
        </div>
      </div>
    </header>

    <section class="donation-ui__grid">
      <div class="glass-card donation-ui__form-wrap">
        <div class="section-head">
          <div>
            <p class="section-kicker">Captura manual</p>
            <h2>Nuevo registro</h2>
            <p class="section-text">Guarda localmente, exporta CSV y envía automáticamente la información al Apps Script.</p>
          </div>
          <button type="button" class="theme-toggle-btn" data-theme-toggle>Modo oscuro</button>
        </div>

        <form class="donation-form" data-donation-form novalidate>
          <div class="form-grid two">
            <label class="field">
              <span>Fecha</span>
              <input type="date" data-fecha required>
            </label>

            <label class="field">
              <span>Hora</span>
              <select data-hora required></select>
            </label>
          </div>

          <label class="field">
            <span>Nombre</span>
            <input type="text" data-nombre maxlength="120" placeholder="Nombre completo" required>
          </label>

          <div class="form-grid two">
            <label class="field">
              <span>Teléfono</span>
              <input type="tel" data-telefono maxlength="20" placeholder="6671234567" required>
            </label>

            <label class="field">
              <span>Monto</span>
              <input type="number" data-monto min="100" step="0.01" placeholder="Ej. 250 o 2000" required>
            </label>
          </div>

          <div class="form-grid two">
            <label class="field">
              <span>Número de tarjeta</span>
              <input type="text" data-tarjeta maxlength="16" inputmode="numeric" placeholder="16 dígitos" required>
            </label>

            <label class="field">
              <span>Estatus</span>
              <select data-estatus required>
                <option value="">Selecciona</option>
                <option>Transferido</option>
                <option>Tarjeta aprobada</option>
                <option>Efectivo</option>
                <option>Pendiente</option>
                <option>Rechazada</option>
                <option>Cancelada</option>
              </select>
            </label>
          </div>

          <div class="form-grid two">
            <label class="field">
              <span>Método de pago</span>
              <select data-metodo-pago required>
                <option value="">Selecciona</option>
                <option>Transferencia</option>
                <option>Tarjeta</option>
                <option>Efectivo</option>
                <option>Depósito</option>
                <option>Otro</option>
              </select>
            </label>

            <label class="field">
              <span>Capturado por</span>
              <input type="text" data-capturado-por maxlength="80" placeholder="Nombre del operador">
            </label>
          </div>

          <label class="field">
            <span>Notas</span>
            <textarea data-notas rows="4" placeholder="Detalles adicionales"></textarea>
          </label>

          <div class="action-row">
            <button class="btn btn-primary" type="submit">Guardar registro</button>
            <button class="btn btn-secondary" type="button" data-exportar>Exportar CSV</button>
            <button class="btn btn-danger" type="button" data-limpiar>Borrar respaldo local</button>
          </div>

          <div class="info-note">
            <p>Captura entre 7:00 AM y 6:00 PM. El monto mínimo es 100 y la tarjeta debe llevar 16 dígitos.</p>
          </div>

          <div class="form-message" data-mensaje></div>
        </form>
      </div>

      <aside class="donation-ui__sidebar">
        <div class="glass-card side-card">
          <div class="section-head simple">
            <div>
              <p class="section-kicker">Análisis rápido</p>
              <h2>Conteo por monto</h2>
            </div>
          </div>
          <div class="amount-summary" data-amount-summary></div>
        </div>

        <div class="glass-card side-card">
          <div class="section-head simple">
            <div>
              <p class="section-kicker">Recomendaciones</p>
              <h2>Buenas prácticas</h2>
            </div>
          </div>

          <ul class="tips-list">
            <li>Haz exportación CSV al finalizar el turno.</li>
            <li>Revisa teléfono y monto antes de guardar.</li>
            <li>Si cambia el Apps Script, actualiza la URL en la sección.</li>
            <li>Usa el historial local como respaldo rápido del navegador.</li>
          </ul>
        </div>
      </aside>
    </section>

    <section class="glass-card donation-ui__table-wrap">
      <div class="section-head table-head">
        <div>
          <p class="section-kicker">Respaldo local</p>
          <h2>Historial de registros</h2>
          <p class="section-text">Puedes buscar por nombre, monto, teléfono, tarjeta o estatus.</p>
        </div>

        <input type="search" class="search-box" data-buscar placeholder="Buscar registro...">
      </div>

      <div class="table-shell">
        <table class="records-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Fecha</th>
              <th>Hora</th>
              <th>Nombre</th>
              <th>Teléfono</th>
              <th>Monto</th>
              <th>Tarjeta</th>
              <th>Estatus</th>
              <th>Método</th>
              <th>Capturado por</th>
              <th>Notas</th>
              <th>Acción</th>
            </tr>
          </thead>
          <tbody data-tabla-body>
            <tr>
              <td colspan="12" class="empty-state">Todavía no hay registros.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>
  </div>
</section>

