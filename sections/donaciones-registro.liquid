{
  "name": "Registro donaciones",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto de badge",
      "default": "Sistema conectado a Google Sheets"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Registro de Donaciones"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subtítulo",
      "default": "Captura donaciones, guarda respaldo local y envía cada registro a tu hoja automáticamente."
    },
    {
      "type": "text",
      "id": "apps_script_url",
      "label": "URL de Apps Script",
      "info": "Pega aquí la URL de tu Google Apps Script publicado como aplicación web.",
      "default": ""
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Color principal",
      "default": "#7c5cff"
    },
    {
      "type": "color",
      "id": "secondary_color",
      "label": "Color secundario / acento",
      "default": "#22d3ee"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Espacio arriba (px)",
      "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Espacio abajo (px)",
