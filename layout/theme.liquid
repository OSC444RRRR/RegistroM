<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#0f172a">
    <title>{{ page_title }}{% if current_tags %} – {{ current_tags | join: ', ' }}{% endif %}{% if current_page != 1 %} – Página {{ current_page }}{% endif %}{% unless page_title contains shop.name %} – {{ shop.name }}{% endunless %}</title>
    {{ content_for_header }}
    <style>
      body {
        margin: 0;
        font-family: Inter, system-ui, Arial, sans-serif;
        background: #0b1020;
      }
    </style>
  </head>
  <body>
    {{ content_for_layout }}
  </body>
</html>